# .env.example — variables de entorno para desarrollo local en MtdrSpring/backend
# Copiar este archivo a .env y completar los valores reales.

# Oracle Autonomous Database
ORACLE_DB_USERNAME=ADMIN
ORACLE_DB_PASSWORD=your-oracle-db-password-here
DB_URL=jdbc:oracle:thin:@chatbotdb_high?TNS_ADMIN=wallet

# Spring Security
SPRING_ADMIN_USER=admin
SPRING_ADMIN_PASSWORD=choose-a-strong-password-here

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_BOT_NAME=Eq51_bot

# DeepSeek AI
DEEPSEEK_API_KEY=your-deepseek-api-key-here
