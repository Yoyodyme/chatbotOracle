# =============================================================================
# .env.example — chatbotOracle
# Copiar este archivo a MtdrSpring/backend/.env y completar los valores reales.
# NUNCA subir el archivo .env al repositorio.
# =============================================================================
# El wallet de Oracle ADB ya está incluido en el repo (MtdrSpring/backend/wallet/).
# No necesitas descargar nada adicional de OCI para conectarte a la base de datos.
# =============================================================================

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Token obtenido desde @BotFather en Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_BOT_NAME=Eq51_bot

# ── DeepSeek AI ───────────────────────────────────────────────────────────────
# Clave obtenida desde https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# ── Oracle ADB ────────────────────────────────────────────────────────────────
# Usuario y contraseña del esquema en Oracle Cloud (pedir al líder del equipo)
ORACLE_DB_USERNAME=ADMIN
ORACLE_DB_PASSWORD=your-oracle-db-password-here

# ── Spring Security ───────────────────────────────────────────────────────────
# Credenciales HTTP Basic para acceder a la API (Postman, bot, frontend)
SPRING_ADMIN_USER=admin
SPRING_ADMIN_PASSWORD=choose-a-strong-password-here
