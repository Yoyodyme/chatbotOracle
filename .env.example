# =============================================================================
# .env.example — chatbotOracle
# Copy this file to .env and fill in real values.
# NEVER commit .env to the repository.
# =============================================================================

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_BOT_NAME=Eq51_bot

# ── DeepSeek AI ───────────────────────────────────────────────────────────────
# Get from https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# ── Oracle ADB (production only, not needed for dev profile) ──────────────────
# Schema/user created in Oracle Cloud Database Actions
ORACLE_DB_USERNAME=your-oracle-schema-username
ORACLE_DB_PASSWORD=your-oracle-db-password

# ── Spring Security ───────────────────────────────────────────────────────────
# HTTP Basic credentials for API access (Postman, bot, etc.)
SPRING_ADMIN_USER=admin
SPRING_ADMIN_PASSWORD=choose-a-strong-password-here
